# ─── App ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dropship"
JWT_SECRET="change-me-in-production"

# ─── Shopify ────────────────────────────────────────────
SHOPIFY_API_KEY="your-shopify-api-key"
SHOPIFY_API_SECRET="your-shopify-api-secret"
SHOPIFY_ADMIN_ACCESS_TOKEN="your-admin-token"
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_WEBHOOK_SECRET="your-webhook-secret"
SHOPIFY_API_VERSION="2024-10"

# ─── AliExpress (RapidAPI / AliExpress Open Platform) ──
ALIEXPRESS_RAPIDAPI_KEY="your-rapidapi-key"
ALIEXPRESS_RAPIDAPI_HOST="aliexpress-datahub.p.rapidapi.com"
ALIEXPRESS_AFFILIATE_ID="your-affiliate-id"

# ─── DSers ──────────────────────────────────────────────
DSERS_API_KEY="your-dsers-api-key"
DSERS_API_SECRET="your-dsers-api-secret"
DSERS_WAREHOUSE_ID="default"

# ─── JungleScout ────────────────────────────────────────
JUNGLE_SCOUT_API_KEY="your-junglescout-api-key"
JUNGLE_SCOUT_EMAIL="your-junglescout-email"

# ─── Admin login (issues JWTs via POST /auth/login) ─────
ADMIN_EMAIL="admin@example.com"
# Generate with: npm run hash-password -- 'your-password'
ADMIN_PASSWORD_HASH="salt-hex:hash-hex"
